{
  "productName": "Shelf",
  "version": "0.2.22",
  "identifier": "com.shelf.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node scripts/package-runner.mjs dev",
    "beforeBuildCommand": "node scripts/package-runner.mjs build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Shelf",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
